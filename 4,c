#include <stdio.h>

int main() {
    float nota, maior;
    int i;

    for (i = 1; i <= 5; i++) {
        printf("Digite a nota %d: ", i);
        scanf("%f", &nota);

        if (i == 1 || nota > maior) {
            maior = nota;
        }
    }

    printf("Maior nota: %.2f\n", maior);

    return 0;
}
